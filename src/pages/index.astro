---
import { Image } from "astro:assets";
import { getRelativeLocaleUrl } from "astro:i18n";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import { useTranslations } from "@/i18n";
import config from "@/config";
import githubStats, {
  formatGitHubCount,
  getRepoStars,
} from "@/utils/githubStats";
import { getAssetPath } from "@/utils/withBase";

const { socials } = config;

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const homePath = getRelativeLocaleUrl(locale, "");

const stats = [
  {
    label: "public repos",
    value: formatGitHubCount(githubStats.profile.publicRepos),
  },
  {
    label: "GitHub followers",
    value: formatGitHubCount(githubStats.profile.followers),
  },
  { label: "home base", value: "Shanghai" },
];

const focusAreas = [
  "AI-assisted engineering",
  "macOS and desktop utilities",
  "browser AI experiments",
  "small tools that make developer workflows visible",
];

const selectedProjects = [
  {
    name: "keyStats",
    href: "https://github.com/debugtheworldbot/keyStats",
    live: "https://keystats.vercel.app",
    description: "Keyboard and mouse analytics for macOS and Windows.",
    language: "Swift",
    stars: getRepoStars("keyStats"),
  },
  {
    name: "ai-credit",
    href: "https://github.com/debugtheworldbot/ai-credit",
    live: "https://ai-credits.vercel.app",
    description:
      "CLI for tracking and analyzing AI coding assistants' contributions inside a codebase.",
    language: "TypeScript",
    stars: getRepoStars("ai-credit"),
  },
  {
    name: "msync",
    href: "https://github.com/debugtheworldbot/msync",
    description: "Syncs Claude Code memories into Claude clients.",
    language: "JavaScript",
    stars: getRepoStars("msync"),
  },
  {
    name: "chromegemini",
    href: "https://github.com/debugtheworldbot/chromegemini",
    live: "https://chromeai.org",
    description:
      "Chrome AI test page for running Gemini Nano locally in the browser.",
    language: "TypeScript",
    stars: getRepoStars("chromegemini"),
  },
];

const dailyToolkit = [
  {
    name: "Raycast",
    href: "https://www.raycast.com/",
    logo: "https://www.google.com/s2/favicons?domain=raycast.com&sz=128",
    category: "Launcher",
  },
  {
    name: "Shottr",
    href: "https://shottr.cc/",
    logo: "https://www.google.com/s2/favicons?domain=shottr.cc&sz=128",
    category: "Capture",
  },
  {
    name: "Codex",
    href: "https://openai.com/codex/",
    logo: "https://www.google.com/s2/favicons?domain=openai.com&sz=128",
    category: "Agents",
  },
  {
    name: "cmux",
    href: "https://cmux.com/",
    logo: "https://www.google.com/s2/favicons?domain=cmux.com&sz=128",
    category: "Agents",
  },
  {
    name: "OpenUsage",
    href: "https://www.openusage.ai/",
    logo: getAssetPath("toolkit/openusage.png"),
    category: "Usage",
  },
  {
    name: "Zed",
    href: "https://zed.dev/",
    logo: "https://www.google.com/s2/favicons?domain=zed.dev&sz=128",
    category: "Editor",
  },
  {
    name: "Ghostty",
    href: "https://ghostty.org/",
    logo: "https://www.google.com/s2/favicons?domain=ghostty.org&sz=128",
    category: "Terminal",
  },
  {
    name: "Fork",
    href: "https://fork.dev/",
    logo: "https://www.google.com/s2/favicons?domain=fork.dev&sz=128",
    category: "Git",
  },
  {
    name: "OrbStack",
    href: "https://orbstack.dev/",
    logo: "https://www.google.com/s2/favicons?domain=orbstack.dev&sz=128",
    category: "Dev env",
  },
  {
    name: "TablePlus",
    href: "https://tableplus.com/",
    logo: "https://www.google.com/s2/favicons?domain=tableplus.com&sz=128",
    category: "Data",
  },
  {
    name: "Figma",
    href: "https://www.figma.com/",
    logo: "https://www.google.com/s2/favicons?domain=figma.com&sz=128",
    category: "Design",
  },
  {
    name: "LocalSend",
    href: "https://localsend.org/",
    logo: "https://www.google.com/s2/favicons?domain=localsend.org&sz=128",
    category: "Transfer",
  },
];
---

<Layout>
  <Header />
  <main
    id="main-content"
    data-layout="index"
    data-home-path={homePath}
    class="app-layout"
  >
    <section id="hero" class="border-border border-b pt-8 pb-8 sm:pt-12">
      <div class="flex flex-col gap-8 sm:flex-row sm:items-center">
        <div class="flex-1">
          <p
            class="text-accent mb-3 text-sm font-semibold tracking-wide uppercase"
          >
            debugtheworldbot / pipizhu
          </p>
          <h1 class="my-4 text-4xl leading-tight font-bold sm:text-5xl">
            I build AI tools and developer utilities.
          </h1>
          <div class="mt-6 flex flex-wrap gap-3">
            <LinkButton
              href="https://github.com/debugtheworldbot"
              target="_blank"
              rel="noreferrer"
              class="border-border rounded-md border px-4 py-2 font-medium"
            >
              GitHub
              <IconArrowRight class="inline-block rtl:-rotate-180" />
            </LinkButton>
            <LinkButton
              href={getRelativeLocaleUrl(locale, "about")}
              class="border-border rounded-md border px-4 py-2 font-medium"
            >
              About
              <IconArrowRight class="inline-block rtl:-rotate-180" />
            </LinkButton>
          </div>
        </div>

        <div class="sm:w-44">
          <Image
            src="https://avatars.githubusercontent.com/u/62830430?v=4"
            alt="debugtheworldbot GitHub avatar"
            width={176}
            height={176}
            loading="eager"
            class="border-border bg-muted mx-auto size-36 rounded-full border object-cover sm:size-44"
          />
        </div>
      </div>

      <dl class="mt-8 grid gap-3 sm:grid-cols-3">
        {
          stats.map(item => (
            <div class="border-border rounded-md border px-4 py-3">
              <dt class="text-foreground/60 text-sm">{item.label}</dt>
              <dd class="mt-1 text-2xl font-semibold">{item.value}</dd>
            </div>
          ))
        }
      </dl>

      <ul class="mt-6 flex flex-wrap gap-2">
        {
          focusAreas.map(area => (
            <li class="bg-muted text-foreground/80 rounded-md px-3 py-1 text-sm">
              {area}
            </li>
          ))
        }
      </ul>

      {
        socials.length > 0 && (
          <div class="mt-4 flex max-sm:flex-col sm:items-center">
            <div class="me-2 mb-1 whitespace-nowrap sm:mb-0">
              {t.home.socialLinks}:
            </div>
            <Socials />
          </div>
        )
      }
    </section>

    <section id="projects" class="border-border border-b pt-12 pb-8">
      <div
        class="mb-6 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between"
      >
        <div>
          <p class="text-accent text-sm font-semibold tracking-wide uppercase">
            selected projects
          </p>
          <h2 class="mt-2 text-2xl font-semibold tracking-wide">
            Tools with public traction
          </h2>
        </div>
        <LinkButton
          href="https://github.com/debugtheworldbot?tab=repositories"
          target="_blank"
          rel="noreferrer"
          class="font-medium"
        >
          All repositories
          <IconArrowRight class="inline-block rtl:-rotate-180" />
        </LinkButton>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        {
          selectedProjects.map(project => (
            <article class="border-border rounded-md border p-5">
              <div class="flex flex-wrap items-start justify-between gap-3">
                <h3 class="text-xl font-semibold">
                  <a
                    href={project.href}
                    target="_blank"
                    rel="noreferrer"
                    class="hover:text-accent"
                  >
                    {project.name}
                  </a>
                </h3>
                <span class="text-foreground/60 text-sm">
                  {project.language} / {project.stars} stars
                </span>
              </div>
              <p class="text-foreground/75 mt-3 leading-7">
                {project.description}
              </p>
              <div class="mt-4 flex flex-wrap gap-4 text-sm font-medium">
                <a
                  href={project.href}
                  target="_blank"
                  rel="noreferrer"
                  class="hover:text-accent"
                >
                  Source
                </a>
                {project.live && (
                  <a
                    href={project.live}
                    target="_blank"
                    rel="noreferrer"
                    class="hover:text-accent"
                  >
                    Live
                  </a>
                )}
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section id="toolkit" class="border-border border-b pt-12 pb-8">
      <div
        class="mb-6 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between"
      >
        <div>
          <p class="text-accent text-sm font-semibold tracking-wide uppercase">
            daily toolkit
          </p>
          <h2 class="mt-2 text-2xl font-semibold tracking-wide">
            Apps I keep close
          </h2>
        </div>
        <p class="text-accent text-sm font-semibold tracking-wide uppercase">
          public-safe picks
        </p>
      </div>

      <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4">
        {
          dailyToolkit.map(tool => (
            <a
              href={tool.href}
              target="_blank"
              rel="noreferrer"
              class="border-border group hover:border-accent/70 flex items-center gap-3 rounded-md border p-3 transition-colors"
            >
              <span class="flex size-10 shrink-0 items-center justify-center">
                <img
                  src={tool.logo}
                  alt={`${tool.name} logo`}
                  loading="lazy"
                  width="28"
                  height="28"
                  class="size-7 rounded-sm object-contain"
                />
              </span>
              <span class="min-w-0">
                <span class="group-hover:text-accent block leading-tight font-semibold">
                  {tool.name}
                </span>
                <span class="text-foreground/55 mt-0.5 block text-xs leading-tight">
                  {tool.category}
                </span>
              </span>
            </a>
          ))
        }
      </div>
    </section>

    <div class="my-8 text-center">
      <LinkButton href={getRelativeLocaleUrl(locale, "posts")}>
        {t.home.allPosts}
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset;
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (indexLayout?.layout) {
      sessionStorage.setItem("backUrl", indexLayout.homePath ?? baseRoot);
    }
  });
</script>
